# Day 10 Lab — copy thành .env và điền nếu cần
#   cp .env.example .env

# ChromaDB (khuyến nghị tách collection khỏi Day 09)
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION=day10_kb_qwen3

# Embedding local qua Ollama
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=qwen3-embedding:0.6b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_TIMEOUT=120

# Freshness SLA (giờ) — dùng trong monitoring/freshness_check.py
FRESHNESS_SLA_HOURS=24

# Tuỳ chọn: OpenRouter chỉ cần nếu nhóm mở rộng eval bằng LLM-judge / agent.
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openrouter/owl-alpha
